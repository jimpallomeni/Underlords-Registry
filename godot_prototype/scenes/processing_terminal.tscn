theme_override_colors/font_hover_color = Color(0.3, 1, 0.3, 1)
text = "[1] APPROVE ROUTING"
flat = true
alignment = 0

[node name="BtnException" type="Button" parent="TerminalPanel/MarginContainer/VBoxContainer/ActionButtons"]
visible = false
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.7, 0.1, 1)
theme_override_colors/font_hover_color = Color(1, 0.85, 0.2, 1)
text = "[1] CONFIRM EXCEPTION HOLD"
flat = true
alignment = 0

[node name="BtnOverride" type="Button" parent="TerminalPanel/MarginContainer/VBoxContainer/ActionButtons"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)
theme_override_colors/font_hover_color = Color(0.8, 0.8, 0.8, 1)
