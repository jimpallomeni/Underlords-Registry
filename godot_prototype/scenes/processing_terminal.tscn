[gd_scene load_steps=3 format=3 uid="uid://terminal_scene"]

[ext_resource type="Script" path="res://scripts/terminal/processing_terminal.gd" id="1_terminal"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.05, 0.08, 0.05, 0.95)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.2, 0.6, 0.2, 1)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4

[node name="ProcessingTerminal" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_terminal")

[node name="TerminalPanel" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -400.0
offset_top = -300.0
offset_right = 400.0
offset_bottom = 300.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="MarginContainer" type="MarginContainer" parent="TerminalPanel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="VBoxContainer" type="VBoxContainer" parent="TerminalPanel/MarginContainer"]
layout_mode = 2

[node name="Header" type="Label" parent="TerminalPanel/MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.2, 0.8, 0.2, 1)
theme_override_font_sizes/font_size = 18
text = "REGISTRY SOUL PROCESSING TERMINAL v7.4.1"
horizontal_alignment = 1

[node name="Separator1" type="HSeparator" parent="TerminalPanel/MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_styles/separator = null

[node name="SoulInfo" type="RichTextLabel" parent="TerminalPanel/MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
text = "Loading soul data..."
scroll_following = true

[node name="Separator2" type="HSeparator" parent="TerminalPanel/MarginContainer/VBoxContainer"]
layout_mode = 2

[node name="ActionButtons" type="VBoxContainer" parent="TerminalPanel/MarginContainer/VBoxContainer"]
layout_mode = 2

[node name="BtnApprove" type="Button" parent="TerminalPanel/MarginContainer/VBoxContainer/ActionButtons"]
